# Babel — Environment Variables Template
# Copy this file to .env and fill in values.
# Never commit .env to version control.

# ----- Model Cache / Download Paths -----
# Where HuggingFace models are cached (avoids re-downloading on every Colab session)
# On Colab/Kaggle, point this to a mounted Google Drive or Kaggle dataset folder
HF_HOME=/path/to/your/model/cache
TORCH_HOME=/path/to/your/torch/cache

# ----- Wav2Lip -----
# Absolute path to the cloned Wav2Lip repository
WAV2LIP_REPO_PATH=/path/to/Wav2Lip

# Absolute path to the downloaded Wav2Lip checkpoint
# Download wav2lip_gan.pth from: https://github.com/Rudrabha/Wav2Lip/releases
WAV2LIP_CHECKPOINT_PATH=/path/to/wav2lip_gan.pth

# ----- IndicTrans2 -----
# Model variant: "ai4bharat/indictrans2-en-indic-1B" (recommended, fits T4)
# Do NOT use 3.3B on free-tier GPU — it will OOM
INDICTRANS2_MODEL_NAME=ai4bharat/indictrans2-en-indic-1B

# ----- Whisper -----
# Model size: tiny, base, small, medium (default), large-v3
# medium is recommended for speed/quality balance on T4
WHISPER_MODEL_SIZE=medium

# ----- XTTS-v2 -----
# Model name as recognized by TTS library
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2

# ----- Output -----
# Default directory for pipeline output files
OUTPUT_DIR=./outputs

# ----- Logging -----
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
